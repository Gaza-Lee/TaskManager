@page "/tasks/inprogress"
@using TaskManager.Models
@using TaskManager.Services
@inject ITaskService TaskService
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation
@inject TaskStateService TaskState
@inject BrowserService Browser
@implements IDisposable

<PageTitle>In Progress Tasks - Task Hub</PageTitle>

<div class="container mx-auto px-4 pb-20 max-w-7xl animate-in fade-in slide-in-from-bottom-4 duration-500">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">
        <div class="flex items-center gap-4">
            <button class="w-10 h-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:bg-white/10 transition-all" @onclick='() => Navigation.NavigateTo("/")'>
                <i class="bi bi-arrow-left"></i>
            </button>
            <div>
                <h1 class="text-3xl font-black text-white tracking-tight">Active Initiatives</h1>
                <p class="text-slate-400 text-sm">Tasks being executed by the team.</p>
            </div>
        </div>
        <div class="px-4 py-2 rounded-2xl border border-amber-500/20 flex items-center gap-3">
            <span class="text-amber-500 font-bold text-xs uppercase tracking-widest">@(_tasks?.Count ?? 0) Active</span>
        </div>
    </div>

    <div class="flex flex-wrap justify-center gap-2 p-1.5 bg-slate-900/50 border border-white/10 rounded-3xl w-fit mx-auto mb-12 backdrop-blur-sm shadow-inner">
        <button class="px-6 py-2.5 rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all @(_currentTab == "all" ? "bg-indigo-600 text-white shadow-lg shadow-indigo-600/30 active:scale-95" : "text-slate-500 hover:text-white hover:bg-white/5")" @onclick='() => _currentTab = "all"'>
            All Tasks
        </button>
        <button class="flex items-center gap-2 px-6 py-2.5 rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all @(_currentTab == "assistance" ? "bg-rose-600 text-white shadow-lg shadow-rose-600/30 active:scale-95" : "text-slate-500 hover:text-white hover:bg-white/5")" @onclick='() => _currentTab = "assistance"'>
            <span>Help</span>
            @if (_needingHelp.Any()) { <span class="px-1.5 py-0.5 rounded-md bg-white/10 text-[9px]">@_needingHelp.Count</span> }
        </button>
        <button class="flex items-center gap-2 px-6 py-2.5 rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all @(_currentTab == "modified" ? "bg-amber-600 text-black shadow-lg shadow-amber-600/30 active:scale-95" : "text-slate-500 hover:text-white hover:bg-white/5")" @onclick='() => _currentTab = "modified"'>
            <span>Modified</span>
            @if (_needingMod.Any()) { <span class="px-1.5 py-0.5 rounded-md bg-black/10 text-[9px]">@_needingMod.Count</span> }
        </button>
        <button class="px-6 py-2.5 rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all @(_currentTab == "ontrack" ? "bg-emerald-600 text-white shadow-lg shadow-emerald-600/30 active:scale-95" : "text-slate-500 hover:text-white hover:bg-white/5")" @onclick='() => _currentTab = "ontrack"'>
            On Track
        </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @{
            var displayTasks = _currentTab switch {
                "assistance" => _needingHelp,
                "modified" => _needingMod,
                "ontrack" => _onTrack,
                _ => _tasks ?? new()
            };
        }

        @if (displayTasks.Any())
        {
            @foreach (var task in displayTasks)
            {
                var isHighlighted = task.Id.ToString() == HighlightId;
                var isActive = task.Id == TaskState.ActiveTaskId;
                <div id="task-@task.Id" class="h-full @(isHighlighted ? "ring-2 ring-indigo-500 ring-offset-2 ring-offset-slate-950 rounded-2xl" : "") @(isActive ? "task-active" : "")">
                    <TaskCard Task="task" OnStatusChanged="LoadTasks" OnOpenRemarks="t => _drawer!.Open(t)" />
                </div>
            }
        }
        else
        {
            <div class="col-span-full flex flex-col items-center justify-center py-20 bg-white/5 border border-dashed border-white/10 rounded-3xl">
                <div class="w-20 h-20 rounded-full bg-slate-800 flex items-center justify-center mb-6 text-slate-500">
                    <i class="bi bi-inbox text-3xl"></i>
                </div>
                <h3 class="text-white font-bold mb-1">Clear Horizons</h3>
                <p class="text-slate-500 text-xs">No tasks found in this category.</p>
            </div>
        }
    </div>

    @if (_tasks != null && !_tasks.Any())
    {
        <div class="flex flex-col items-center justify-center py-32">
            <div class="w-32 h-32 rounded-full bg-indigo-600/10 flex items-center justify-center mb-8 relative">
                <div class="absolute inset-0 rounded-full border border-indigo-500/20 animate-ping"></div>
                <i class="bi bi-hourglass-top text-4xl text-indigo-400"></i>
            </div>
            <h2 class="text-2xl font-black text-white mb-2">Workspace Quiet</h2>
            <p class="text-slate-400 max-w-sm text-center text-sm mb-8">No initiatives currently in execution. Time to browse for new challenges!</p>
            <button class="px-8 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-black text-xs uppercase tracking-widest rounded-full shadow-2xl shadow-indigo-600/20 transition-all active:scale-95 flex items-center gap-3" @onclick='() => Navigation.NavigateTo("/tasks/available")'>
                <i class="bi bi-search"></i>
                Discover Tasks
            </button>
        </div>
    }
</div>

<RemarkDrawer @ref="_drawer" CurrentUser="@_currentUser" OnRemarkAdded="LoadTasks" />

@code {
    [SupplyParameterFromQuery(Name = "highlight")]
    public string? HighlightId { get; set; }

    private List<TaskItem>? _tasks;
    private string? _currentUser;
    private RemarkDrawer? _drawer;
    private string _currentTab = "all";
    private List<TaskItem> _needingMod => (_tasks ?? new()).Where(t => t.NeedsModification).ToList();
    private List<TaskItem> _needingHelp => (_tasks ?? new()).Where(t => t.NeedsHelp && !t.NeedsModification).ToList();
    private List<TaskItem> _onTrack => (_tasks ?? new()).Where(t => !t.NeedsHelp && !t.NeedsModification).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var user = await UserIdentity.GetCurrentUserAsync();
            _currentUser = user;
            if (string.IsNullOrWhiteSpace(user))
            {
                Navigation.NavigateTo("/set-name");
                return;
            }

            if (!string.IsNullOrWhiteSpace(HighlightId))
            {
                await Browser.ScrollToElementAsync($"task-{HighlightId}");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        TaskState.OnChange += StateHasChanged;
        TaskService.OnTasksChanged += HandleTasksChanged;
        await LoadTasks();
    }

    public void Dispose()
    {
        TaskState.OnChange -= StateHasChanged;
        TaskService.OnTasksChanged -= HandleTasksChanged;
    }

    private async void HandleTasksChanged()
    {
        try
        {
            await InvokeAsync(async () => {
                await LoadTasks();
                StateHasChanged();
            });
        }
        catch { /* component disposed */ }
    }

    private async Task LoadTasks()
    {
        var all = await TaskService.GetTasksAsync();
        _tasks = all.Where(t => t.Status == TaskItemStatus.InProgress)
                    .OrderByDescending(t => t.CreatedAt)
                    .ToList();
    }
}

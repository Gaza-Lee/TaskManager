@page "/"
@using System
@using TaskManager.Models
@using TaskManager.Services
@inject ITaskService TaskService
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Dashboard - Task Hub</PageTitle>

<div class="animate-in fade-in duration-700 max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-black text-white tracking-tighter mb-0.5">Team Hub</h1>
            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Collective Objective Stream</p>
        </div>
        <div class="w-full md:w-64 group relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                <i class="bi bi-search text-slate-500 text-xs"></i>
            </div>
            <input type="text" class="w-full bg-white/5 border border-white/10 text-white text-[11px] pl-10 pr-4 py-2 rounded-lg focus:outline-none focus:border-indigo-500/40 focus:bg-white/[0.08] transition-all" 
                   placeholder="Search..." 
                   @bind="_searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
        </div>
    </div>

    @if (_tasks == null)
    {
        <div class="flex items-center justify-center py-32">
            <div class="w-12 h-12 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
            <!-- Available Tasks Card -->
            <StatusPreviewCard 
                Title="Available" 
                Description="Unassigned Initiatives" 
                Tasks="@(_tasks.Where(t => t.Status == TaskItemStatus.Available).ToList())"
                HrefPath="/tasks/available" />

            <!-- In Progress Tasks Card -->
            <StatusPreviewCard 
                Title="In Progress" 
                Description="In Execution" 
                Tasks="@(_tasks.Where(t => t.Status == TaskItemStatus.InProgress).ToList())"
                HrefPath="/tasks/inprogress" />

            <!-- Completed Tasks Card -->
            <StatusPreviewCard 
                Title="Completed" 
                Description="Finalized Work" 
                Tasks="@(_tasks.Where(t => t.Status == TaskItemStatus.Completed).OrderByDescending(t => t.CompletedAt).ToList())"
                HrefPath="/tasks/completed" />
        </div>

        <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl overflow-hidden shadow-2xl">
            <div class="px-8 py-5 border-b border-white/5 flex items-center justify-between">
                <h2 class="text-xs font-black text-white uppercase tracking-widest">
                    Recent Activity
                </h2>
                <div class="text-[9px] text-slate-500 font-bold uppercase tracking-widest bg-white/5 px-2.5 py-0.5 rounded-full">
                    Last 8 Events
                </div>
            </div>
            
            <div class="divide-y divide-white/5">
                @if (!_tasks.Any())
                {
                    <div class="text-center py-10 text-slate-600 font-bold uppercase tracking-widest text-[9px] italic">
                        Silence in the forge... No activity yet.
                    </div>
                }
                else
                {
                    @foreach (var task in _tasks.OrderByDescending(t => t.Status == TaskItemStatus.Completed ? t.CompletedAt : t.CreatedAt).Take(8))
                    {
                        <div class="flex justify-between items-center group hover:bg-white/[0.02] transition-colors p-4">
                            <div class="flex flex-col gap-1">
                                <div class="text-xs text-white font-bold group-hover:text-indigo-400 transition-colors">@task.Title</div>
                                <div class="flex items-center gap-2">
                                    @if (task.Status == TaskItemStatus.Completed)
                                    {
                                        <span class="text-[9px] text-emerald-400 px-2 py-0.5 rounded-md font-black uppercase tracking-widest border border-emerald-500/30">Done</span>
                                    }
                                    else if (task.NeedsHelp)
                                    {
                                        <span class="text-[9px] text-rose-500 px-2 py-0.5 rounded-md font-black uppercase tracking-widest border border-rose-500/30">Help Needed</span>
                                    }
                                    else if (task.Status == TaskItemStatus.InProgress)
                                    {
                                        <span class="text-[9px] text-sky-400 px-2 py-0.5 rounded-md font-black uppercase tracking-widest border border-sky-500/30">Active</span>
                                    }
                                    else
                                    {
                                        <span class="text-[9px] text-indigo-400 px-2 py-0.5 rounded-md font-black uppercase tracking-widest border border-indigo-500/30">Manifested</span>
                                    }
                                    @{
                                        var roleLabel = task.Status switch {
                                            TaskItemStatus.Available => "Assigned to:",
                                            TaskItemStatus.InProgress => "Accepted by:",
                                            _ => "Completed by:"
                                        };
                                        var participant = task.Status switch {
                                            TaskItemStatus.Available => task.AssignedTo,
                                            TaskItemStatus.InProgress => !string.IsNullOrWhiteSpace(task.AcceptedBy) ? task.AcceptedBy : task.AssignedTo,
                                            _ => !string.IsNullOrWhiteSpace(task.CompletedBy) 
                                                 ? task.CompletedBy 
                                                 : (!string.IsNullOrWhiteSpace(task.AcceptedBy) ? task.AcceptedBy : task.AssignedTo)
                                        };
                                    }
                                    <span class="text-[9px] text-slate-500 italic ml-2">@roleLabel @participant</span>
                                </div>
                            </div>
                            <a href="@GetStatusHref(task.Status)" class="w-10 h-10 rounded-full flex items-center justify-center text-slate-600 hover:text-white hover:bg-white/10 transition-all no-underline">
                                <i class="bi bi-arrow-up-right"></i>
                            </a>
                        </div>
                    }
                }
            </div>
            <div class="bg-indigo-600/[0.03] p-4 text-center">
                <p class="text-[8px] text-indigo-400/50 uppercase font-black tracking-[0.2em]">End of Transmission</p>
            </div>
        </div>
    }
</div>

@code {
    private List<TaskItem>? _tasks;
    private string _searchQuery = "";
    private string? _userName;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            UserIdentity.OnUserChanged += HandleUserChanged;
            TaskService.OnTasksChanged += HandleTasksChanged;
            _userName = await UserIdentity.GetCurrentUserAsync();
            if (string.IsNullOrWhiteSpace(_userName))
            {
                Navigation.NavigateTo("/set-name");
            }
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        _tasks = await TaskService.GetTasksAsync();
    }

    private async Task HandleSearch()
    {
        _tasks = await TaskService.SearchTasksAsync(_searchQuery);
    }

    private async void HandleUserChanged()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                _userName = await UserIdentity.GetCurrentUserAsync();
                await LoadTasks();
                StateHasChanged();
            });
        }
        catch { /* component disposed */ }
    }

    private async void HandleTasksChanged()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                await LoadTasks();
                StateHasChanged();
            });
        }
        catch { /* component disposed */ }
    }

    public void Dispose()
    {
        UserIdentity.OnUserChanged -= HandleUserChanged;
        TaskService.OnTasksChanged -= HandleTasksChanged;
    }

    private static string GetStatusHref(TaskItemStatus status) => status switch
    {
        TaskItemStatus.Available  => "/tasks/available",
        TaskItemStatus.InProgress => "/tasks/inprogress",
        TaskItemStatus.Completed  => "/tasks/completed",
        _ => "/"
    };
}

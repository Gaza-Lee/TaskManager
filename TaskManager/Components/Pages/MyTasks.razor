@page "/my-tasks"
@using TaskManager.Models
@using TaskManager.Services
@inject ITaskService TaskService
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation
@inject TaskStateService TaskState
@implements IDisposable

<PageTitle>My Tasks - Task Hub</PageTitle>

<div class="container mx-auto px-4 pb-12 max-w-7xl animate-in fade-in slide-in-from-bottom-4 duration-500">
    @if (_userName == null)
    {
        <div class="flex items-center justify-center py-20">
            <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else
    {
        <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div>
                <h1 class="text-3xl font-black text-white tracking-tighter mb-1">My Task Hub</h1>
                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Personal initiative stream</p>
            </div>
            
            <div class="flex p-1 bg-white/5 rounded-xl border border-white/5">
                <button class='px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all @(_activeTab == "to-me" ? "bg-indigo-600 text-white shadow-lg shadow-indigo-600/20" : "text-slate-500 hover:text-white")' 
                        @onclick='() => SetTab("to-me")'>Assigned To Me</button>
                <button class='px-4 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest transition-all @(_activeTab == "by-me" ? "bg-indigo-600 text-white shadow-lg shadow-indigo-600/20" : "text-slate-500 hover:text-white")' 
                        @onclick='() => SetTab("by-me")'>Assigned By Me</button>
            </div>
        </div>

        <!-- Statistics Section -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
            @foreach (var stat in new[] { ("Today", _stats.Today), ("Week", _stats.ThisWeek), ("Month", _stats.ThisMonth), ("Year", _stats.ThisYear) })
            {
                <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-2xl p-4 text-center shadow-lg group hover:border-indigo-500/20 transition-all">
                    <div class="text-[8px] text-slate-600 font-black uppercase tracking-widest mb-1">@stat.Item1</div>
                    <div class="text-2xl font-black text-white group-hover:text-indigo-400 transition-colors">@stat.Item2</div>
                </div>
            }
        </div>

        <div class="space-y-10">
            <section>
                <div class="flex items-center justify-between mb-6 border-b border-white/5 pb-3">
                    <h2 class="text-lg font-black text-white tracking-tight flex items-center gap-3">
                        <span class="w-7 h-7 rounded-lg bg-amber-500/10 border border-amber-500/30 flex items-center justify-center">
                            <i class="bi bi-lightning-charge-fill text-amber-500 text-xs"></i>
                        </span>
                        Active
                    </h2>
                    @if (_inProgressTasks.Any())
                    {
                        <span class="px-2 py-0.5 bg-amber-500/10 text-amber-500 rounded-md text-[8px] font-black uppercase border border-amber-500/20">
                            @_inProgressTasks.Count Tasks
                        </span>
                    }
                </div>

                @{
                    var needingHelp = _inProgressTasks.Where(t => t.NeedsHelp && !t.NeedsModification).ToList();
                    var needingMod = _inProgressTasks.Where(t => t.NeedsModification).ToList();
                    var onTrack = _inProgressTasks.Where(t => !t.NeedsHelp && !t.NeedsModification).ToList();
                }

                @if (needingMod.Any() || needingHelp.Any())
                {
                    <div class="mb-8">
                        <h3 class="text-[8px] font-black uppercase tracking-[0.2em] text-rose-500 mb-4 px-1 flex items-center gap-2">
                            <span class="w-1 h-1 rounded-full bg-rose-500 animate-pulse"></span>
                            Action Required
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            @foreach (var task in needingMod)
                            {
                                <div id="task-@task.Id" class="h-full @(task.Id == TaskState.ActiveTaskId ? "task-active" : "")">
                                    <TaskCard Task="task" OnStatusChanged="LoadData" OnOpenRemarks="t => _drawer!.Open(t)" />
                                </div>
                            }
                            @foreach (var task in needingHelp)
                            {
                                <div id="task-@task.Id" class="h-full @(task.Id == TaskState.ActiveTaskId ? "task-active" : "")">
                                    <TaskCard Task="task" OnStatusChanged="LoadData" OnOpenRemarks="t => _drawer!.Open(t)" />
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (onTrack.Any())
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        @foreach (var task in onTrack)
                        {
                            <div id="task-@task.Id" class="h-full @(task.Id == TaskState.ActiveTaskId ? "task-active" : "")">
                                <TaskCard Task="task" OnStatusChanged="LoadData" OnOpenRemarks="t => _drawer!.Open(t)" />
                            </div>
                        }
                    </div>
                }
                
                @if (!_inProgressTasks.Any())
                {
                    <div class="bg-white/5 border border-dashed border-white/10 rounded-[2rem] py-12 text-center">
                        <div class="w-14 h-14 rounded-full bg-slate-800 flex items-center justify-center mx-auto mb-4 text-slate-600">
                            <i class="bi bi-cup-hot-fill text-xl"></i>
                        </div>
                        <p class="text-slate-600 font-bold uppercase tracking-widest text-[8px]">No Active Objectives</p>
                        <button class="mt-6 px-6 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-black text-[10px] uppercase tracking-widest rounded-full transition-all active:scale-95" @onclick='() => Navigation.NavigateTo("/tasks/available")'>
                            Browse Queue
                        </button>
                    </div>
                }
            </section>

            <section>
                <div class="flex items-center justify-between mb-6 border-b border-white/5 pb-3">
                    <h2 class="text-lg font-black text-white tracking-tight flex items-center gap-3">
                        <span class="w-7 h-7 rounded-lg bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center">
                            <i class="bi bi-check2-all text-emerald-500 text-xs"></i>
                        </span>
                        Successes
                    </h2>
                </div>
                
                @if (!_completedTasks.Any())
                {
                    <p class="text-[9px] text-slate-700 font-bold uppercase tracking-widest italic ml-1">No completed initiatives.</p>
                }
                else
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 opacity-80 backdrop-grayscale hover:backdrop-grayscale-0 transition-all duration-500">
                        @foreach (var task in _completedTasks.Take(6))
                        {
                            <div id="task-@task.Id" class="h-full @(task.Id == TaskState.ActiveTaskId ? "task-active" : "")">
                                <TaskCard Task="task" OnStatusChanged="LoadData" OnOpenRemarks="t => _drawer!.Open(t)" />
                            </div>
                        }
                    </div>
                }
            </section>
        </div>
    }
</div>

<RemarkDrawer @ref="_drawer" CurrentUser="@_userName" OnRemarkAdded="LoadData" />

@code {
    private string? _userName;
    private string _activeTab = "to-me";
    private List<TaskItem> _inProgressTasks = new();
    private List<TaskItem> _completedTasks = new();
    private CompletionStats _stats = new();
    private RemarkDrawer? _drawer;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _userName = await UserIdentity.GetCurrentUserAsync();
            if (string.IsNullOrWhiteSpace(_userName))
            {
                Navigation.NavigateTo("/set-name");
                return;
            }
            await LoadData();
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        TaskState.OnChange += StateHasChanged;
        await LoadData();
    }

    public void Dispose()
    {
        TaskState.OnChange -= StateHasChanged;
    }
    private async Task SetTab(string tab)
    {
        _activeTab = tab;
        await LoadData();
    }

    private async Task LoadData()
    {
        if (_userName == null) return;
        
        var all = await TaskService.GetTasksAsync();
        
        IEnumerable<TaskItem> filtered;
        if (_activeTab == "to-me")
        {
            filtered = all.Where(t =>
                t.AssignedTo.Equals(_userName, StringComparison.OrdinalIgnoreCase) ||
                t.AcceptedBy.Equals(_userName, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            filtered = all.Where(t => t.AssignedBy.Equals(_userName, StringComparison.OrdinalIgnoreCase));
        }

        var userTasks = filtered.ToList();
        
        _inProgressTasks = userTasks.Where(t => t.Status == TaskItemStatus.InProgress).OrderByDescending(t => t.CreatedAt).ToList();
        
        // Successes logic: 
        // If "Assigned To Me", show tasks I completed.
        // If "Assigned By Me", show tasks I assigned that are now completed.
        if (_activeTab == "to-me")
        {
             _completedTasks = all.Where(t => t.Status == TaskItemStatus.Completed && t.CompletedBy.Equals(_userName, StringComparison.OrdinalIgnoreCase))
                               .OrderByDescending(t => t.CompletedAt).ToList();
        }
        else
        {
            _completedTasks = userTasks.Where(t => t.Status == TaskItemStatus.Completed)
                               .OrderByDescending(t => t.CompletedAt).ToList();
        }
        
        CalculateStats(userTasks);
        StateHasChanged();
    }

    private void CalculateStats(List<TaskItem> userTasks)
    {
        var now = DateTime.UtcNow;
        var completed = userTasks.Where(t => t.Status == TaskItemStatus.Completed && t.CompletedAt.HasValue).ToList();
        
        _stats.Today = completed.Count(t => t.CompletedAt!.Value.Date == now.Date);
        
        var startOfWeek = now.AddDays(-(int)now.DayOfWeek);
        _stats.ThisWeek = completed.Count(t => t.CompletedAt!.Value.Date >= startOfWeek.Date);
        
        _stats.ThisMonth = completed.Count(t => t.CompletedAt!.Value.Month == now.Month && t.CompletedAt!.Value.Year == now.Year);
        _stats.ThisYear = completed.Count(t => t.CompletedAt!.Value.Year == now.Year);
        _stats.AllTime = completed.Count;
    }

    private class CompletionStats
    {
        public int Today { get; set; }
        public int ThisWeek { get; set; }
        public int ThisMonth { get; set; }
        public int ThisYear { get; set; }
        public int AllTime { get; set; }
    }
}

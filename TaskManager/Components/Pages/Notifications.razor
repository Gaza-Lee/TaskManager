@page "/notifications"
@using TaskManager.Models
@using TaskManager.Services
@inject INotificationService NotificationService
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation

<PageTitle>Notifications - Task Hub</PageTitle>

<div class="container mx-auto px-4 pb-20 max-w-4xl animate-in fade-in slide-in-from-bottom-4 duration-500">
    @if (_userName == null)
    {
        <div class="flex items-center justify-center py-32">
            <div class="w-10 h-10 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else
    {
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div>
                <h1 class="text-xl font-black text-white tracking-tight mb-0.5">Alert Feed</h1>
                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Collective Records</p>
            </div>
            @if (_notifications != null && _notifications.Any(n => !n.IsRead))
            {
                <button class="px-4 py-1.5 bg-white/5 hover:bg-white/10 text-slate-500 hover:text-white border border-white/10 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all active:scale-95" @onclick="MarkAllAsRead">
                    Clear Alerts
                </button>
            }
        </div>

        <div class="space-y-12">
            @if (_notifications == null)
            {
                <div class="flex items-center justify-center py-20">
                    <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
                </div>
            }
            else if (!_notifications.Any())
            {
                <div class="bg-slate-900/40 backdrop-blur-md border border-dashed border-white/10 rounded-[2.5rem] p-20 text-center">
                    <div class="w-20 h-20 rounded-full bg-slate-800 flex items-center justify-center mx-auto mb-6 text-slate-600">
                        <i class="bi bi-bell-slash text-3xl"></i>
                    </div>
                    <p class="text-slate-500 font-bold uppercase tracking-widest text-[10px]">No Transmissions Found</p>
                </div>
            }
            else
            {
                var grouped = _notifications.GroupBy(n => n.CreatedAt.Date).OrderByDescending(g => g.Key);
                @foreach (var group in grouped)
                {
                    <div>
                        <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-600 mb-6 px-1">
                            @GetGroupHeader(group.Key)
                        </h3>
                        <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl overflow-hidden shadow-2xl divide-y divide-white/5">
                            @foreach (var notification in group)
                            {
                                <div class="group p-4 hover:bg-white/[0.02] cursor-pointer transition-all @(notification.IsRead ? "opacity-40" : "bg-indigo-500/[0.03]") relative"
                                     @onclick="() => HandleNotificationClick(notification)">
                                    @if (!notification.IsRead)
                                    {
                                        <div class="absolute left-0 top-0 bottom-0 w-1 bg-indigo-500"></div>
                                    }
                                    <div class="flex gap-4 items-start">
                                        <div class="flex-shrink-0">
                                            <div class="w-10 h-10 rounded-xl bg-slate-800/80 flex items-center justify-center border border-white/5 transition-transform group-hover:scale-105 shadow-lg">
                                                <i class="bi @GetIcon(notification.Type) @(notification.IsRead ? "text-slate-600" : GetIconColor(notification.Type)) text-base"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow min-w-0 py-1">
                                            <div class="flex justify-between items-start mb-1 gap-4">
                                                <div class="text-xs text-white font-medium group-hover:text-indigo-400 transition-colors leading-snug">@notification.Message</div>
                                                <div class="text-[9px] text-slate-600 font-bold whitespace-nowrap">@notification.CreatedAt.ToString("HH:mm")</div>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <span class="text-[8px] font-black uppercase tracking-[0.2em] @(notification.IsRead ? "text-slate-700" : "text-indigo-400")">@notification.Type.ToString().ToUpper()</span>
                                                @if (!notification.IsRead)
                                                {
                                                    <span class="text-[8px] font-black uppercase tracking-widest text-indigo-500/40">NEW</span>
                                                }
                                            </div>
                                        </div>
                                        <div class="flex-shrink-0 self-center opacity-0 group-hover:opacity-100 transition-opacity">
                                            <i class="bi bi-chevron-right text-slate-600"></i>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private string? _userName;
    private List<Notification>? _notifications;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _userName = await UserIdentity.GetCurrentUserAsync();
            if (string.IsNullOrWhiteSpace(_userName))
            {
                Navigation.NavigateTo("/set-name");
                return;
            }
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        if (_userName == null) return;
        _notifications = await NotificationService.GetNotificationsForUserAsync(_userName);
        // Sort by date descending
        _notifications = _notifications.OrderByDescending(n => n.CreatedAt).ToList();
    }

    private async Task HandleNotificationClick(Notification notification)
    {
        if (!notification.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notification.Id);
            notification.IsRead = true;
        }
        
        // Navigation logic based on notification type/task
        Navigation.NavigateTo("/my-tasks"); 
    }

    private async Task MarkAllAsRead()
    {
        if (string.IsNullOrWhiteSpace(_userName)) return;
        await NotificationService.MarkAllAsReadAsync(_userName);
        await LoadData();
    }

    private string GetIcon(NotificationType type) => type switch
    {
        NotificationType.RemarkAdded => "bi-chat-dots",
        NotificationType.TaskReassigned => "bi-person-badge",
        NotificationType.AuditHelp => "bi-exclamation-triangle",
        NotificationType.StatusUpdate => "bi-check-circle",
        _ => "bi-bell"
    };

    private string GetIconColor(NotificationType type) => type switch
    {
        NotificationType.RemarkAdded => "text-primary",
        NotificationType.TaskReassigned => "text-info",
        NotificationType.AuditHelp => "text-danger",
        NotificationType.StatusUpdate => "text-success",
        _ => "text-white"
    };

    private string GetGroupHeader(DateTime date)
    {
        var diff = (DateTime.UtcNow.Date - date.Date).Days;
        return diff switch {
            0 => "Signals Today",
            1 => "Signals Yesterday",
            _ => date.ToString("MMMM dd, yyyy").ToUpper()
        };
    }

    private string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.UtcNow - dt;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalDays < 1) return $"{(int)span.TotalHours}h ago";
        return dt.ToString("MMM dd");
    }
}

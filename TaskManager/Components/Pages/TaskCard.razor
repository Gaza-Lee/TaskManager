@using TaskManager.Models
@using TaskManager.Services
@inject ITaskService TaskService
@inject UserIdentityService UserIdentity

<div class="group relative bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-2xl p-5 hover:bg-slate-900/60 hover:border-white/20 transition-all shadow-xl hover:shadow-2xl flex flex-col h-full">

    <div class="flex justify-between items-start mb-4">
        @{
            var statusLabel = Task.Status switch {
                TaskItemStatus.Available => "Available",
                TaskItemStatus.InProgress when Task.NeedsHelp => "Need Assistance",
                TaskItemStatus.InProgress when Task.NeedsModification => "Modified",
                TaskItemStatus.InProgress => "On Track",
                _ => "Completed"
            };
            var statusColor = Task.Status switch {
                TaskItemStatus.Available => "text-indigo-400 border-indigo-500/30",
                TaskItemStatus.InProgress when Task.NeedsHelp => "text-rose-500 border-rose-500/30",
                TaskItemStatus.InProgress when Task.NeedsModification => "text-amber-500 border-amber-500/30",
                TaskItemStatus.InProgress => "text-sky-400 border-sky-500/30",
                _ => "text-emerald-400 border-emerald-500/30"
            };
        }
        <span class="inline-flex items-center px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-[0.2em] border @statusColor shadow-sm">
            @statusLabel
        </span>

        <div class="flex items-center gap-1">
            @if (_currentUser == Task.AssignedBy)
            {
                <button class="flex items-center justify-center w-7 h-7 rounded-lg text-slate-500 hover:text-rose-400 hover:bg-rose-500/10 transition-all active:scale-90" 
                        title="Delete Objective" @onclick="DeleteTask">
                    <i class="bi bi-trash text-sm"></i>
                </button>
            }
        </div>
    </div>

    <h3 class="text-lg font-black text-white mb-2 tracking-tight leading-tight group-hover:text-indigo-400 transition-colors">@Task.Title</h3>
    <p class="text-xs text-slate-400 leading-relaxed line-clamp-3 group-hover:line-clamp-none transition-all group-hover:text-slate-300">@Task.Description</p>

    @if (Task.NeedsHelp && !string.IsNullOrWhiteSpace(Task.HelpDetails))
    {
        <div class="mt-4 p-3 rounded-xl border border-rose-500/10 group/help">
            <div class="text-[9px] font-black text-rose-500/60 mb-1.5 uppercase tracking-widest flex items-center">
                <i class="bi bi-patch-question mr-2 group-hover/help:animate-pulse"></i>Assistance Requested
            </div>
            <p class="text-xs text-slate-300 italic leading-relaxed pl-5 border-l border-rose-500/20">@Task.HelpDetails</p>
        </div>
    }

    @if (Task.NeedsModification && !string.IsNullOrWhiteSpace(Task.HelpDetails))
    {
        <div class="mt-4 p-3 rounded-xl border border-amber-500/10 group/mod">
            <div class="text-[9px] font-black text-amber-500/60 mb-1.5 uppercase tracking-widest flex items-center justify-between">
                <span><i class="bi bi-pencil-square mr-2 group-hover/mod:animate-pulse"></i>Latest Modification Request</span>
                @if (Task.ModificationHistory?.Any() == true)
                {
                    <button class="text-[9px] text-slate-600 hover:text-amber-500 flex items-center transition-colors" 
                            @onclick="() => _showModHistory = !_showModHistory">
                        <i class="bi @(_showModHistory ? "bi-eye-slash" : "bi-clock-history") mr-1.5"></i>
                        @(_showModHistory ? "Hide Logs" : $"{Task.ModificationHistory.Count} Previous")
                    </button>
                }
            </div>
            <p class="text-xs text-slate-300 leading-relaxed pl-5 border-l border-amber-500/20">@Task.HelpDetails</p>

            @if (_showModHistory && Task.ModificationHistory?.Any() == true)
            {
                <div class="mt-3 pt-3 border-t border-white/5 space-y-3 max-h-32 overflow-y-auto custom-scrollbar pr-1">
                    @foreach (var oldMsg in Task.ModificationHistory.AsEnumerable().Reverse())
                    {
                        <div class="relative pl-4 border-l border-white/5 py-1">
                            <div class="absolute -left-px top-2 w-1 h-3 bg-amber-500/20"></div>
                            <div class="text-[9px] text-slate-500 font-bold uppercase tracking-wider mb-1">Archived Mod</div>
                            <div class="text-[11px] text-slate-400 italic">@oldMsg</div>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (Task.Status == TaskItemStatus.Completed && !string.IsNullOrWhiteSpace(Task.AuditRemark))
    {
        <div class="mt-4 p-4 rounded-xl border border-emerald-500/20">
            <div class="text-[10px] font-bold text-emerald-400 mb-1 uppercase tracking-widest flex items-center">
                <i class="bi bi-patch-check-fill mr-2"></i>Audit / Feedback
            </div>
            <p class="text-xs text-slate-200 leading-relaxed">@Task.AuditRemark</p>
        </div>
    }

    <div class="mt-auto pt-4">
        <div class="pt-3 border-t border-white/5 mb-4">
            <div class="flex flex-col gap-3">
                <div class="flex items-center justify-between">
                    <div class="text-[8px] text-slate-500 font-bold tracking-widest">Assigned by:</div>
                    <div class="text-[11px] text-white font-bold">@Task.AssignedBy</div>
                </div>

                @{
                    var roleLabel = Task.Status switch {
                        TaskItemStatus.Available => "Assigned to:",
                        TaskItemStatus.InProgress => "Accepted by:",
                        _ => "Completed by:"
                    };
                    var roleParticpant = Task.Status switch {
                        TaskItemStatus.Available => Task.AssignedTo,
                        TaskItemStatus.InProgress => !string.IsNullOrWhiteSpace(Task.AcceptedBy) ? Task.AcceptedBy : Task.AssignedTo,
                        _ => !string.IsNullOrWhiteSpace(Task.CompletedBy) 
                             ? Task.CompletedBy 
                             : (!string.IsNullOrWhiteSpace(Task.AcceptedBy) ? Task.AcceptedBy : Task.AssignedTo)
                    };
                }

                @if (!string.IsNullOrWhiteSpace(roleParticpant))
                {
                    <div class="flex items-center justify-between">
                        <div class="text-[8px] text-slate-500 font-bold tracking-widest">@roleLabel</div>
                        <div class="text-[11px] text-white font-bold">@roleParticpant</div>
                    </div>
                }
            </div>
            <div class="mt-4 text-[9px] text-slate-600 font-medium flex items-center justify-center border-t border-white/[0.03] pt-3">
                @Task.CreatedAt.ToString("MMM dd HH:mm")
            </div>
        </div>

        <div class="flex flex-col gap-2 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">
            @if (Task.Status == TaskItemStatus.Available)
            {
                <button class="w-full py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-black text-[10px] tracking-widest shadow-lg shadow-indigo-600/20 transition-all active:scale-95 uppercase" @onclick="() => _showConfirmAccept = true">
                    <i class="bi bi-person-check-fill mr-2"></i>Accept Objective
                </button>
            }
            else if (Task.Status == TaskItemStatus.InProgress)
            {
                <div class="flex gap-2">
                    @if (IsCurrentUserTheWorker)
                    {
                        <button class="flex-1 py-2.5 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-black text-[10px] tracking-widest shadow-lg shadow-emerald-600/20 transition-all active:scale-95 uppercase" @onclick="() => _showConfirmDone = true">
                            <i class="bi bi-check-circle-fill mr-2"></i>Done
                        </button>
                        
                        <button class="px-4 py-2.5 rounded-xl border border-rose-500/30 text-rose-400 hover:bg-rose-500/10 font-bold text-[10px] transition-all active:scale-95 uppercase" @onclick="() => _isRequestingHelp = true">
                            <i class="bi bi-question-circle mr-2"></i>Assistance
                        </button>
                    }
                    else if (Task.NeedsHelp || Task.NeedsModification)
                    {
                        <button class="w-full py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-black text-[10px] tracking-widest shadow-lg shadow-indigo-600/20 transition-all active:scale-95 uppercase" @onclick="AcceptHelpRequest">
                            <i class="bi bi-hand-thumbs-up-fill mr-2"></i>Take Over
                        </button>
                    }
                    else
                    {
                        <div class="w-full py-2.5 rounded-xl bg-slate-800 text-slate-500 text-center font-bold text-[9px] border border-white/5 italic">
                            Currently In Execution
                        </div>
                    }
                </div>
            }
            else if (Task.Status == TaskItemStatus.Completed)
            {
                <button class="w-full py-2.5 rounded-xl border border-sky-500/30 text-sky-400 hover:bg-sky-500/10 font-black text-[9px] tracking-widest transition-all active:scale-95 uppercase mb-1" @onclick="() => _isReopening = true">
                    <i class="bi bi-arrow-counterclockwise mr-2"></i>REOPEN FOR MODIFICATION
                </button>
            }

            <button class="w-full text-[9px] text-slate-500 hover:text-indigo-400 mt-1 flex items-center justify-center gap-1.5 opacity-60 hover:opacity-100 transition-all border border-white/5 hover:border-indigo-500/30 rounded-xl py-1.5" @onclick="() => OnOpenRemarks.InvokeAsync(Task)">
                <i class="bi bi-chat-right-text"></i>
                <span>@(Task.Remarks?.Count ?? 0) @(Task.Remarks?.Count == 1 ? "Remark" : "Remarks")</span>
            </button>
        </div>
    </div>

</div>

@if (_showConfirmAccept)
{
    <ConfirmationDialog Title="Accept Task?" Message="Are you ready to start working on this initiative?" ConfirmText="ACCEPT" OnConfirm="ConfirmAccept" OnCancel="() => _showConfirmAccept = false" />
}

@if (_showConfirmDone)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-in fade-in duration-200">
        <div class="w-full max-w-sm bg-slate-900 border border-white/10 rounded-2xl p-6 shadow-2xl animate-in zoom-in-95 duration-200">
            <h3 class="text-xl font-bold text-white mb-2">Well Done!</h3>
            <p class="text-xs text-slate-400 mb-4">Add a brief summary (optional):</p>
            <textarea class="w-full bg-white/5 border border-white/10 text-white text-xs px-4 py-3 rounded-xl focus:outline-none focus:border-emerald-500/50 transition-colors mb-6 resize-none" 
                      rows="3" @bind="_completionRemark" placeholder="e.g. Optimized the SQL queries..."></textarea>
            <div class="grid grid-cols-2 gap-3">
                <button class="py-2.5 rounded-full border border-white/10 text-slate-400 hover:text-white hover:bg-white/5 font-bold text-xs" @onclick="() => { _showConfirmDone = false; _completionRemark = string.Empty; }">
                    CANCEL
                </button>
                <button class="py-2.5 rounded-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs shadow-lg shadow-emerald-600/20" @onclick="ConfirmDone">
                    COMPLETE
                </button>
            </div>
        </div>
    </div>
}

@if (_isRequestingHelp)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-in fade-in duration-200">
        <div class="w-full max-w-sm bg-slate-900 border border-white/10 rounded-2xl p-6 shadow-2xl animate-in zoom-in-95 duration-200">
            <h3 class="text-xl font-bold text-white mb-2 text-rose-400">Request Help</h3>
            <p class="text-xs text-slate-400 mb-4">Describe what you're stuck on:</p>
            <textarea class="w-full bg-white/5 border border-white/10 text-white text-xs px-4 py-3 rounded-xl focus:outline-none focus:border-rose-500/50 transition-colors mb-6 resize-none" 
                      rows="3" @bind="_helpDetails" placeholder="e.g. Need clarification on the API endpoints..."></textarea>
            <div class="grid grid-cols-2 gap-3">
                <button class="py-2.5 rounded-full border border-white/10 text-slate-400 hover:text-white hover:bg-white/5 font-bold text-xs" @onclick="() => { _isRequestingHelp = false; _helpDetails = string.Empty; }">
                    CANCEL
                </button>
                <button class="py-2.5 rounded-full bg-rose-600 hover:bg-rose-500 text-white font-bold text-xs shadow-lg shadow-rose-600/20" @onclick="SubmitHelpRequest">
                    POST
                </button>
            </div>
        </div>
    </div>
}

@if (_isAuditing)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-in fade-in duration-200">
        <div class="w-full max-w-sm bg-slate-900 border border-white/10 rounded-2xl p-6 shadow-2xl animate-in zoom-in-95 duration-200">
            <h3 class="text-xl font-bold text-white mb-2 text-sky-400">Audit Review</h3>
            <p class="text-xs text-slate-400 mb-4">Leave your feedback:</p>
            <textarea class="w-full bg-white/5 border border-white/10 text-white text-xs px-4 py-3 rounded-xl focus:outline-none focus:border-sky-500/50 transition-colors mb-6 resize-none" 
                      rows="3" @bind="_auditRemark" placeholder="e.g. Great work, but please check..."></textarea>
            <div class="space-y-3">
                <div class="grid grid-cols-2 gap-3">
                    <button class="py-2.5 rounded-full border border-white/10 text-slate-400 hover:text-white hover:bg-white/5 font-bold text-xs" @onclick="() => { _isAuditing = false; _auditRemark = string.Empty; }">
                        CANCEL
                    </button>
                    <button class="py-2.5 rounded-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs" @onclick="ConfirmAuditStayDone">
                        PASS AUDIT
                    </button>
                </div>
                <button class="w-full py-2.5 rounded-full bg-amber-600 hover:bg-amber-500 text-slate-950 font-bold text-xs shadow-lg shadow-amber-600/20" @onclick="AuditBackToInProgress">
                    SEND BACK FOR MODIFICATION
                </button>
            </div>
        </div>
    </div>
}

@if (_isReopening)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-in fade-in duration-200">
        <div class="w-full max-w-sm bg-slate-900 border border-white/10 rounded-2xl p-6 shadow-2xl animate-in zoom-in-95 duration-200">
            <h3 class="text-xl font-bold text-white mb-2 text-amber-500">Reopen Objective</h3>
            <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-4">Specify Modification Requirements</p>
            <textarea class="w-full bg-white/5 border border-white/10 text-white text-xs px-4 py-3 rounded-xl focus:outline-none focus:border-amber-500/50 transition-colors mb-6 resize-none" 
                      rows="3" @bind="_reopenReason" placeholder="Describe what needs to be changed..."></textarea>
            <div class="grid grid-cols-2 gap-3">
                <button class="py-2.5 rounded-full border border-white/10 text-slate-400 hover:text-white hover:bg-white/5 font-bold text-xs transition-colors" @onclick="() => { _isReopening = false; _reopenReason = string.Empty; }">
                    CANCEL
                </button>
                <button class="py-2.5 rounded-full bg-amber-600 hover:bg-amber-500 text-slate-950 font-black text-xs shadow-lg shadow-amber-600/20 transition-all active:scale-95" 
                        disabled="@(string.IsNullOrWhiteSpace(_reopenReason))" @onclick="ConfirmReopen">
                    REOPEN FOR MODIFICATION
                </button>
            </div>
        </div>
    </div>
}

@if (_showConfirmDelete)
{
    <ConfirmationDialog Title="Delete Task?" Message="Are you sure you want to permanently delete this task? This action cannot be undone." ConfirmText="DELETE" OnConfirm="ConfirmDelete" OnCancel="() => _showConfirmDelete = false" />
}

@code {
    [Parameter] public TaskItem Task { get; set; } = default!;
    [Parameter] public EventCallback OnStatusChanged { get; set; }
    [Parameter] public EventCallback<TaskItem> OnOpenRemarks { get; set; }

    private string? _currentUser;
    private bool _showConfirmAccept;
    private bool _showConfirmDone;
    private string _completionRemark = "";

    private bool _isRequestingHelp;
    private string _helpDetails = "";

    private bool _isAuditing;
    private string _auditRemark = "";
    private bool _showModHistory;

    private bool _isReopening;
    private string _reopenReason = "";
    private bool _showConfirmDelete;

    private bool IsCurrentUserTheWorker =>
        !string.IsNullOrWhiteSpace(_currentUser) &&
        (Task.AssignedTo.Equals(_currentUser, StringComparison.OrdinalIgnoreCase) ||
         Task.AcceptedBy.Equals(_currentUser, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentUser = await UserIdentity.GetCurrentUserAsync();
            StateHasChanged();
        }
    }

    private async Task ConfirmAccept()
    {
        _showConfirmAccept = false;
        if (!string.IsNullOrWhiteSpace(_currentUser))
        {
            Task.AcceptedBy = _currentUser;
        }
        Task.Status = TaskItemStatus.InProgress;
        Task.NeedsModification = false;
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task ConfirmDone()
    {
        _showConfirmDone = false;
        Task.Status = TaskItemStatus.Completed;
        Task.CompletedAt = DateTime.UtcNow;
        Task.CompletedBy = _currentUser ?? "Unknown";
        Task.AuditRemark = _completionRemark;
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task SubmitHelpRequest()
    {
        _isRequestingHelp = false;
        Task.NeedsHelp = true;
        Task.HelpDetails = _helpDetails;
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task AcceptHelpRequest()
    {
        if (string.IsNullOrWhiteSpace(_currentUser)) return;
        
        Task.AcceptedBy = _currentUser;
        Task.NeedsHelp = false;
        Task.NeedsModification = false;
        Task.HelpDetails = "";
        
        await TaskService.AddRemarkAsync(Task.Id, new TaskRemark {
            Author = _currentUser,
            Content = "I've accepted this task and am taking over to move it forward."
        });
        
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task ConfirmAuditStayDone()
    {
        _isAuditing = false;
        Task.AuditRemark = _auditRemark;
        Task.CompletedBy = _currentUser ?? "Unknown";
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task AuditBackToInProgress()
    {
        _isAuditing = false;
        
        if (Task.NeedsModification && !string.IsNullOrWhiteSpace(Task.HelpDetails))
        {
            Task.ModificationHistory.Add(Task.HelpDetails);
        }
        
        Task.Status = TaskItemStatus.InProgress;
        Task.AuditRemark = _auditRemark;
        Task.NeedsModification = true;
        Task.NeedsHelp = false;
        Task.HelpDetails = _auditRemark;
        
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task ConfirmReopen()
    {
        if (string.IsNullOrWhiteSpace(_reopenReason)) return;
        
        _isReopening = false;
        
        var reason = _reopenReason;
        _reopenReason = string.Empty;

        Task.Status = TaskItemStatus.InProgress;
        Task.NeedsModification = true;
        Task.NeedsHelp = false;
        Task.HelpDetails = reason;
        Task.AuditRemark = string.Empty;
        
        await TaskService.AddRemarkAsync(Task.Id, new TaskRemark {
            Author = _currentUser ?? "Unknown",
            Content = $"Action: Reopened for Modification. Reason: {reason}"
        });
        
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task ReopenTask()
    {
        // Replaced by ConfirmReopen with dialogue
    }

    private async Task UpdateStatus(TaskItemStatus newStatus)
    {
        Task.Status = newStatus;
        if (newStatus != TaskItemStatus.InProgress)
        {
            Task.NeedsModification = false;
            Task.NeedsHelp = false;
        }
        await TaskService.UpdateTaskAsync(Task);
        await OnStatusChanged.InvokeAsync();
    }

    private async Task ConfirmDelete()
    {
        _showConfirmDelete = false;
        if (!string.IsNullOrWhiteSpace(_currentUser))
        {
            await TaskService.DeleteTaskAsync(Task.Id, _currentUser);
            await OnStatusChanged.InvokeAsync();
        }
    }

    private void DeleteTask()
    {
        _showConfirmDelete = true;
    }
}
@page "/set-name"
@using TaskManager.Services
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation

<PageTitle>Welcome - Task Hub</PageTitle>

<div class="min-h-[80vh] flex items-center justify-center p-4 animate-in fade-in duration-1000">
    <div class="w-full max-w-sm bg-slate-900/60 backdrop-blur-xl border border-white/10 rounded-[3rem] p-10 shadow-2xl text-center">
        <div class="mb-10 relative inline-block group">
            <div class="absolute inset-0 bg-indigo-500 blur-2xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
            <div class="relative w-20 h-20 rounded-3xl bg-indigo-600 flex items-center justify-center mx-auto shadow-2xl shadow-indigo-600/20 rotate-3 group-hover:rotate-0 transition-transform">
                <i class="bi bi-layers-fill text-white text-4xl"></i>
            </div>
        </div>
        
        <h1 class="text-xl font-black text-white tracking-tighter mb-3">Initialize Identity</h1>
        <p class="text-slate-500 text-sm mb-10 leading-relaxed font-medium">Enter your operative identifier to access the Hub. This is how the team will track your initiatives.</p>

        <div class="space-y-6">
            <div class="relative group">
                <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none text-slate-500 group-focus-within:text-indigo-400 transition-colors">
                    <i class="bi bi-person-fill"></i>
                </div>
                <input type="text" class="w-full bg-white/5 border border-white/10 text-white text-sm pl-12 pr-5 py-3.5 rounded-2xl focus:outline-none focus:border-indigo-500/50 focus:bg-white/[0.08] transition-all text-center font-bold tracking-tight"
                       placeholder="Operative Name"
                       @bind="_name"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
            </div>

            <button class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-500 disabled:bg-slate-800 disabled:text-slate-600 disabled:opacity-50 text-white font-black text-xs uppercase tracking-[0.3em] rounded-2xl shadow-2xl shadow-indigo-600/30 transition-all active:scale-95 flex items-center justify-center gap-3"
                    disabled="@string.IsNullOrWhiteSpace(_name)"
                    @onclick="SaveName">
                CONTINUE
                <i class="bi bi-arrow-right"></i>
            </button>
        </div>
        
        <div class="mt-10 pt-10 border-t border-white/5">
            <p class="text-[9px] text-slate-700 font-bold uppercase tracking-widest">Secure Connection Active</p>
        </div>
    </div>
</div>

@code {
    private string _name = "";

    private async Task SaveName()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;
        await UserIdentity.SetCurrentUserAsync(_name);
        Navigation.NavigateTo("/");
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveName();
    }
}

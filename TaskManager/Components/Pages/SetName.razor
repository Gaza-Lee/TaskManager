@page "/set-name"
@using TaskManager.Services
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation

<PageTitle>Welcome - Task Hub</PageTitle>

<div class="container pb-5">
    <div class="row justify-content-center" style="min-height: 70vh;">
        <div class="col-md-6 col-lg-4 d-flex align-items-center">
            <div class="glass-card text-center">
                <div class="mb-4">
                    <i class="bi bi-layers-fill text-primary display-3"></i>
                </div>
                <h1 class="h3 fw-bold text-white mb-2">Welcome to Task Hub</h1>
                <p class="text-muted small mb-4">Enter your name to get started. This is how your team will see you.</p>

                <div class="mb-4">
                    <input type="text" class="form-control text-center fw-bold"
                           placeholder="Your name"
                           @bind="_name"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>

                <button class="btn btn-primary w-100 py-2 fw-bold"
                        disabled="@string.IsNullOrWhiteSpace(_name)"
                        @onclick="SaveName">
                    <i class="bi bi-arrow-right me-2"></i>Continue
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string _name = "";

    private async Task SaveName()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;
        await UserIdentity.SetCurrentUserAsync(_name);
        Navigation.NavigateTo("/");
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveName();
    }
}

@page "/assign-task"
@using TaskManager.Models
@using TaskManager.Services
@inject ITaskService TaskService
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation

<PageTitle>Create Task - Task Hub</PageTitle>

<div class="container mx-auto px-4 pb-20 max-w-3xl animate-in fade-in slide-in-from-bottom-4 duration-500">
    <div class="mb-10">
        <div class="flex items-center gap-4 mb-2">
            <button class="w-10 h-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:bg-white/10 transition-all font-bold" @onclick="HandleAbort">
                <i class="bi bi-arrow-left"></i>
            </button>
            <h1 class="text-xl font-black text-white tracking-tight">Manifest Initiative</h1>
        </div>
        <p class="text-slate-500 text-xs font-medium">Define a new objective for the collective.</p>
    </div>

    <div class="bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-3xl p-8 shadow-2xl">
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="mb-8 p-4 bg-rose-500/10 border border-rose-500/20 rounded-2xl flex items-center gap-3 animate-in fade-in zoom-in-95">
                <i class="bi bi-exclamation-octagon text-rose-500"></i>
                <span class="text-rose-200 text-xs font-bold">@_errorMessage</span>
            </div>
        }

        <EditForm Model="_newTask" OnSubmit="HandleSubmit" class="space-y-8">
            <div class="space-y-2">
                <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 block ml-1">Objective Title</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500 group-focus-within:text-indigo-400 transition-colors">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <InputText @bind-Value="_newTask.Title" class="w-full bg-white/5 border border-white/10 text-white text-xs pl-11 pr-4 py-3 rounded-2xl focus:outline-none focus:border-indigo-500/50 focus:bg-white/[0.08] transition-all font-bold" placeholder="e.g. Architect the neuro-engine" />
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 block ml-1">Detailed Brief</label>
                <InputTextArea @bind-Value="_newTask.Description" class="w-full bg-white/5 border border-white/10 text-white text-xs px-4 py-3 rounded-2xl focus:outline-none focus:border-indigo-500/50 focus:bg-white/[0.08] transition-all min-h-[120px]" placeholder="Outline the scope and constraints..." />
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 block ml-1">Target Operative</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500 group-focus-within:text-indigo-400 transition-colors">
                        <i class="bi bi-person-plus-fill"></i>
                    </div>
                    <InputText @bind-Value="_newTask.AssignedTo" class="w-full bg-white/5 border border-white/10 text-white text-xs pl-11 pr-4 py-3 rounded-2xl focus:outline-none focus:border-indigo-500/50 focus:bg-white/[0.08] transition-all" placeholder="Assignee identifier..." />
                </div>
            </div>

            <div class="pt-6 flex items-center justify-end gap-6">
                <button type="button" class="text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-white transition-colors" @onclick="HandleAbort">ABORT</button>
                <button type="submit" class="px-10 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-black text-[10px] uppercase tracking-[0.2em] rounded-2xl shadow-2xl shadow-indigo-600/30 transition-all active:scale-95 flex items-center gap-3">
                    <i class="bi bi-plus-lg"></i>
                    CREATE TASK
                </button>
            </div>
        </EditForm>
    </div>
</div>

@if (_showAbortConfirm)
{
    <ConfirmationDialog Title="Discard Initiative?" Message="Any information entered for this objective will be permanently lost." ConfirmText="DISCARD" OnConfirm="GoBack" OnCancel="() => _showAbortConfirm = false" />
}

@code {
    private TaskItem _newTask = new();
    private string? _errorMessage;
    private bool _showAbortConfirm;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var user = await UserIdentity.GetCurrentUserAsync();
            if (string.IsNullOrWhiteSpace(user))
            {
                Navigation.NavigateTo("/set-name");
                return;
            }
            _newTask.AssignedBy = user;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_newTask.Title))
        {
            _errorMessage = "Task title is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_newTask.AssignedTo))
        {
            _errorMessage = "Please specify who the task is for.";
            return;
        }

        try
        {
            _newTask.Status = TaskItemStatus.Available;
            await TaskService.AddTaskAsync(_newTask);
            Navigation.NavigateTo("/tasks/available");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to create task: {ex.Message}";
        }
    }

    private void HandleAbort()
    {
        if (!string.IsNullOrWhiteSpace(_newTask.Title) || !string.IsNullOrWhiteSpace(_newTask.Description))
        {
            _showAbortConfirm = true;
        }
        else
        {
            GoBack();
        }
    }

    private void GoBack() => Navigation.NavigateTo("/");
}

@page "/tasks/available"
@using TaskManager.Models
@using TaskManager.Services
@inject ITaskService TaskService
@inject UserIdentityService UserIdentity
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject TaskStateService TaskState
@inject BrowserService Browser
@implements IDisposable

<PageTitle>Available Tasks - Task Hub</PageTitle>

<div class="container mx-auto px-4 pb-20 max-w-7xl animate-in fade-in slide-in-from-bottom-4 duration-500">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10">
        <div class="flex items-center gap-4">
            <button class="w-10 h-10 rounded-full flex items-center justify-center bg-white/5 border border-white/10 text-slate-400 hover:text-white hover:bg-white/10 transition-all" @onclick='() => Navigation.NavigateTo("/")'>
                <i class="bi bi-arrow-left"></i>
            </button>
            <div>
                <h1 class="text-3xl font-black text-white tracking-tight">Open Queue</h1>
                <p class="text-slate-400 text-sm">Initiatives waiting for a champion.</p>
            </div>
        </div>
        <div class="px-4 py-2 rounded-2xl border border-indigo-500/20 flex items-center gap-3">
            <span class="text-indigo-400 font-bold text-xs uppercase tracking-widest">@(_tasks?.Count ?? 0) Available</span>
        </div>
    </div>

    @if (_tasks == null)
    {
        <div class="flex items-center justify-center py-32">
            <div class="w-10 h-10 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
        </div>
    }
    else if (!_tasks.Any())
    {
        <div class="flex flex-col items-center justify-center py-32 bg-white/5 border border-dashed border-white/10 rounded-3xl">
            <div class="w-20 h-20 rounded-full bg-slate-800 flex items-center justify-center mb-6 text-slate-500">
                <i class="bi bi-inbox text-3xl"></i>
            </div>
            <h2 class="text-xl font-bold text-white mb-2">No Challenges Found</h2>
            <p class="text-slate-500 text-sm mb-8 text-center max-w-xs">All initiatives are currently being handled or have been finalized.</p>
            <button class="px-8 py-3 bg-indigo-600 hover:bg-indigo-500 text-white font-black text-xs uppercase tracking-widest rounded-full shadow-2xl shadow-indigo-600/20 transition-all active:scale-95 flex items-center gap-3" @onclick='() => Navigation.NavigateTo("/assign-task")'>
                <i class="bi bi-plus-lg"></i>
                Create New Initiative
            </button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var task in _tasks)
            {
                var isHighlighted = task.Id.ToString() == HighlightId;
                <div id="task-@task.Id" class="h-full @(isHighlighted ? "ring-2 ring-indigo-500 ring-offset-2 ring-offset-slate-950 rounded-2xl" : "") @(task.Id == TaskState.ActiveTaskId ? "task-active" : "")">
                    <TaskCard Task="task" OnStatusChanged="LoadTasks" OnOpenRemarks="t => _drawer!.Open(t)" />
                </div>
            }
        </div>
    }
</div>

<RemarkDrawer @ref="_drawer" CurrentUser="@_currentUser" OnRemarkAdded="LoadTasks" />

@code {
    [SupplyParameterFromQuery(Name = "highlight")]
    public string? HighlightId { get; set; }

    private List<TaskItem>? _tasks;
    private string? _currentUser;
    private RemarkDrawer? _drawer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var user = await UserIdentity.GetCurrentUserAsync();
            _currentUser = user;
            if (string.IsNullOrWhiteSpace(user))
            {
                Navigation.NavigateTo("/set-name");
                return;
            }

            if (!string.IsNullOrWhiteSpace(HighlightId))
            {
                await Browser.ScrollToElementAsync($"task-{HighlightId}");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        TaskState.OnChange += StateHasChanged;
        await LoadTasks();
    }

    public void Dispose()
    {
        TaskState.OnChange -= StateHasChanged;
    }

    private async Task LoadTasks()
    {
        var all = await TaskService.GetTasksAsync();
        _tasks = all.Where(t => t.Status == TaskItemStatus.Available)
                    .OrderByDescending(t => t.CreatedAt)
                    .ToList();
    }
}

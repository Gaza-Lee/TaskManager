@page "/not-found"
@layout MainLayout

<PageTitle>Not Found - Task Hub</PageTitle>

<div class="flex flex-col items-center justify-center min-h-[70vh] text-center px-4">
    <div class="relative mb-8">
        <div class="w-32 h-32 rounded-full bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center">
            <div class="absolute inset-0 rounded-full border border-indigo-500/20 animate-ping opacity-30"></div>
            <i class="bi bi-search text-4xl text-indigo-400"></i>
        </div>
    </div>

    <p class="text-[9px] font-black uppercase tracking-[0.3em] text-indigo-500/60 mb-3">404</p>
    <h1 class="text-3xl font-black text-white tracking-tighter mb-3">Page Not Found</h1>
    <p class="text-slate-500 text-sm max-w-xs mb-10 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
    </p>

    <a href="/"
       class="px-8 py-3 bg-indigo-600 hover:bg-indigo-500 active:scale-95 text-white font-black text-[10px] uppercase tracking-[0.2em] rounded-full shadow-2xl shadow-indigo-600/30 transition-all no-underline inline-flex items-center gap-3">
        <i class="bi bi-house-fill"></i>
        Back to Dashboard
    </a>
</div>